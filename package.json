  "homepage": "https://github.com/PeshoVurtoleta/lite-snow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeshoVurtoleta/lite-snow.git"
  },
  "bugs": {
    "url": "https://github.com/PeshoVurtoleta/lite-snow/issues",
    "email": "shinikchiev@yahoo.com"
  },
  "dependencies": {
    "@zakkster/lite-color": "^1.0.5"
  },
  "keywords": [
    "snow",
    "snowfall",
    "weather",
