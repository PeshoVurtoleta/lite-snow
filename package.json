{
  "name": "@zakkster/lite-snow",
  "author": "Zahary Shinikchiev <shinikchiev@yahoo.com>",
  "version": "1.0.0",
  "description": "Zero-GC, SoA environmental snow engine with drift physics, Z-depth parallax, ellipse-based accumulation, dimension caching, and off-screen culling. Designed for cinematic snowfall with high-performance rendering and natural flake behavior.",
  "type": "module",
  "main": "SnowEngine.js",
  "types": "SnowEngine.d.ts",
  "exports": {
    ".": {
      "types": "./SnowEngine.d.ts",
      "import": "./SnowEngine.js",
      "default": "./SnowEngine.js"
    }
  },
  "files": [
    "SnowEngine.js",
    "SnowEngine.d.ts",
    "llms.txt",
    "README.md"
  ],
